{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "NEXT_PUBLIC_SUPABASE_URL",
    "NEXT_PUBLIC_SUPABASE_ANON_KEY",
    "NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY",
    "NEXT_PUBLIC_SENTRY_DSN",
    "NEXT_PUBLIC_POSTHOG_KEY",
    "NEXT_PUBLIC_POSTHOG_HOST"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": [
        "app/**",
        "components/**",
        "lib/**",
        "public/**",
        "package.json",
        "tsconfig.json",
        "next.config.*",
        "tailwind.config.*",
        "postcss.config.*"
      ],
      "outputs": [".next/**", "!.next/cache/**", "dist/**", "out/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"],
      "inputs": [
        "app/**",
        "components/**",
        "lib/**",
        "*.config.*",
        "package.json",
        ".eslintrc.*",
        "eslint.config.*"
      ]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "inputs": [
        "app/**",
        "components/**",
        "lib/**",
        "tsconfig.json",
        "tsconfig.*.json",
        "package.json"
      ]
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": [
        "app/**",
        "__tests__/**",
        "vitest.config.*",
        "package.json"
      ]
    },
    "test:e2e": {
      "dependsOn": ["^build"],
      "cache": false,
      "env": ["PLAYWRIGHT_BASE_URL", "CI"]
    }
  }
}
