# =============================================================================
# alexendros-pro — .env.example
# =============================================================================
# Supabase es self-hosted en Dokploy (ADR-0003): endpoint público
# https://supabase.alexendros.pro. NO usar dominios *.supabase.co.

# Supabase (self-hosted)
NEXT_PUBLIC_SUPABASE_URL=https://supabase.alexendros.pro
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROJECT_URL=https://supabase.alexendros.pro

# Prisma · Supavisor (6543) para runtime, directo (5432) para migraciones.
# IMPORTANTE: ?pgbouncer=true&connection_limit=1 en DATABASE_URL para serverless.
DATABASE_URL=postgresql://postgres:PWD@db.supabase.alexendros.pro:6543/postgres?pgbouncer=true&connection_limit=1&pool_timeout=20
DIRECT_URL=postgresql://postgres:PWD@db.supabase.alexendros.pro:5432/postgres?sslmode=require

# Stripe
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_CLIENT_ID=
STRIPE_PRICE_STAGEKIT_PRO_MONTHLY=
STRIPE_PRICE_STAGEKIT_PRO_ANNUAL=
STRIPE_PRICE_STAGEKIT_AGENCY_MONTHLY=
STRIPE_PRICE_STAGEKIT_AGENCY_ANNUAL=
STRIPE_PRICE_STAGEKIT_FREE=

# OAuth (sólo client IDs viven aquí; los secrets están en Dokploy → GoTrue)
GOOGLE_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_ID=
APPLE_OAUTH_CLIENT_ID=

# Email (Resend — también usado por GoTrue self-hosted vía SMTP)
RESEND_API_KEY=

# Monitoring
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com

# Notion MCP
NOTION_TOKEN=

# n8n (Hostinger VPS)
N8N_WEBHOOK_SECRET=
N8N_BASE_URL=https://n8n.example.com

# Rate Limiting (Upstash Redis)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
