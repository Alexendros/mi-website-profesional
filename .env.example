# ===========================================================================
# alexendros-pro — Variables de entorno
# Copiar a .env.local y rellenar. Nunca comitear .env.local.
# Validación: @repo/config/env (Zod). Importar siempre desde @repo/config/env.
# ===========================================================================

# --- Supabase (proyecto: https://supabase.com/dashboard) ---
# Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=
# Settings → API → anon public key (seguro para bundle cliente)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Settings → API → service_role key (NUNCA exponer al cliente)
SUPABASE_SERVICE_ROLE_KEY=

# --- Prisma (Supabase Settings → Database → Connection string) ---
# Transaction mode (pooler, port 6543) — para queries
DATABASE_URL=
# Session mode (directo, port 5432) — para migraciones
DIRECT_URL=

# --- Stripe (https://dashboard.stripe.com/test/apikeys) ---
# Publishable key (pk_test_... o pk_live_...)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Secret key (sk_test_... o sk_live_...)
STRIPE_SECRET_KEY=
# Developers → Webhooks → Signing secret (whsec_...)
STRIPE_WEBHOOK_SECRET=
# Connect → Settings → Platform settings (ca_...)
STRIPE_CONNECT_CLIENT_ID=
# Price IDs para StageKit (crear en Stripe Dashboard → Products)
STRIPE_PRICE_STAGEKIT_PRO_MONTHLY=
STRIPE_PRICE_STAGEKIT_AGENCY_MONTHLY=

# --- Email (https://resend.com/api-keys) ---
# API key con permisos de envío para alexendros.pro (re_...)
RESEND_API_KEY=

# --- Monitoring ---
# Sentry DSN (https://sentry.io → Settings → Projects → Client Keys)
NEXT_PUBLIC_SENTRY_DSN=
# PostHog (https://eu.posthog.com → Project Settings)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com

# --- Notion MCP (https://www.notion.so/my-integrations) ---
NOTION_TOKEN=

# --- n8n (Hostinger VPS) ---
N8N_WEBHOOK_SECRET=
N8N_BASE_URL=https://n8n.example.com

# --- Rate Limiting (https://console.upstash.com → Redis → REST API) ---
# Región recomendada: eu-west-1 (misma que Supabase)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
